{
  "name": "kraken-coder",
  "displayName": "Kraken Coder",
  "description": "AI coding assistant for VS Code with chat, context, and reviewable edits.",
  "version": "0.1.0",
  "publisher": "bill-yan233",
  "license": "MIT",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Programming Languages",
    "Machine Learning",
    "Other"
  ],
  "activationEvents": [
    "onView:krakenCoder.chatView",
    "onCommand:kraken.openChat",
    "onCommand:kraken.configureModel",
    "onCommand:kraken.clearSession",
    "onCommand:kraken.explainSelection",
    "onCommand:kraken.fixSelection",
    "onCommand:kraken.generateTests",
    "onCommand:kraken.addSelectionToContext"
  ],
  "main": "./out/extension.js",
  "scripts": {
    "clean": "rimraf out",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "check": "tsc -p ./ --noEmit",
    "prepackage": "npm run clean && npm run compile",
    "vscode:package": "npm run prepackage && vsce package",
    "vscode:publish": "npm run prepackage && vsce publish"
  },
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "krakenCoder",
          "title": "Kraken Coder",
          "icon": "$(hubot)"
        }
      ]
    },
    "views": {
      "krakenCoder": [
        {
          "type": "webview",
          "id": "krakenCoder.chatView",
          "name": "Chat"
        }
      ]
    },
    "commands": [
      {
        "command": "kraken.openChat",
        "title": "Kraken: Open Chat",
        "category": "Kraken"
      },
      {
        "command": "kraken.configureModel",
        "title": "Kraken: Configure Model",
        "category": "Kraken"
      },
      {
        "command": "kraken.clearSession",
        "title": "Kraken: Clear Session",
        "category": "Kraken"
      },
      {
        "command": "kraken.explainSelection",
        "title": "Kraken: Explain Selection",
        "category": "Kraken"
      },
      {
        "command": "kraken.fixSelection",
        "title": "Kraken: Fix Selection",
        "category": "Kraken"
      },
      {
        "command": "kraken.generateTests",
        "title": "Kraken: Generate Tests",
        "category": "Kraken"
      },
      {
        "command": "kraken.addSelectionToContext",
        "title": "Kraken: Add Selection To Context",
        "category": "Kraken"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "kraken.explainSelection",
          "group": "navigation@20",
          "when": "editorHasSelection"
        },
        {
          "command": "kraken.fixSelection",
          "group": "navigation@21",
          "when": "editorHasSelection"
        },
        {
          "command": "kraken.generateTests",
          "group": "navigation@22"
        },
        {
          "command": "kraken.addSelectionToContext",
          "group": "navigation@23",
          "when": "editorHasSelection"
        }
      ],
      "view/title": [
        {
          "command": "kraken.clearSession",
          "when": "view == krakenCoder.chatView",
          "group": "navigation"
        },
        {
          "command": "kraken.configureModel",
          "when": "view == krakenCoder.chatView",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "Kraken Coder",
      "properties": {
        "kraken.model.baseUrl": {
          "type": "string",
          "default": "https://openrouter.ai/api/v1",
          "description": "Base URL for the selected model provider API."
        },
        "kraken.model.provider": {
          "type": "string",
          "default": "openrouter",
          "description": "Model provider adapter."
        },
        "kraken.model.api": {
          "type": "string",
          "default": "chat-completions",
          "enum": [
            "responses",
            "chat-completions",
            "messages"
          ],
          "description": "Model API mode used by the selected provider."
        },
        "kraken.model.name": {
          "type": "string",
          "default": "qwen/qwen3.6-plus",
          "description": "Model name to use."
        },
        "kraken.model.reasoning.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable provider reasoning or thinking controls when supported."
        },
        "kraken.model.reasoning.effort": {
          "type": "string",
          "default": "medium",
          "enum": [
            "none",
            "minimal",
            "low",
            "medium",
            "high",
            "xhigh",
            "max"
          ],
          "description": "Provider-neutral reasoning effort preference."
        },
        "kraken.model.reasoning.display": {
          "type": "string",
          "default": "hidden",
          "enum": [
            "hidden",
            "summary",
            "visible"
          ],
          "description": "How reasoning or thinking should be displayed when the provider returns it."
        },
        "kraken.model.reasoning.budgetTokens": {
          "type": "number",
          "default": 0,
          "minimum": 0,
          "description": "Provider-neutral reasoning budget hint in tokens. Use 0 for provider default."
        },
        "kraken.model.reasoning.preserve": {
          "type": "boolean",
          "default": false,
          "description": "Preserve reasoning or thinking state across tool loops when supported."
        },
        "kraken.model.reasoning.maxStoredTokens": {
          "type": "number",
          "default": 4096,
          "minimum": 0,
          "description": "Maximum reasoning or thinking tokens Kraken should keep for continuity."
        },
        "kraken.model.cache.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable provider prompt or block cache controls when supported."
        },
        "kraken.model.cache.strategy": {
          "type": "string",
          "default": "auto",
          "enum": [
            "auto",
            "disabled"
          ],
          "description": "Provider cache optimization mode. Auto maps to provider-specific prompt, block, or context cache."
        },
        "kraken.model.cache.retention": {
          "type": "string",
          "default": "in_memory",
          "description": "Provider-neutral cache retention hint."
        },
        "kraken.providers.openai.api": {
          "type": "string",
          "default": "responses",
          "enum": [
            "responses",
            "chat-completions"
          ],
          "description": "OpenAI/GPT API mode."
        },
        "kraken.providers.openai.effort": {
          "type": "string",
          "default": "medium",
          "enum": [
            "none",
            "minimal",
            "low",
            "medium",
            "high",
            "xhigh",
            "max"
          ],
          "description": "OpenAI/GPT reasoning effort."
        },
        "kraken.providers.openai.promptCacheKey": {
          "type": "string",
          "default": "workspace",
          "description": "OpenAI/GPT prompt cache key hint."
        },
        "kraken.providers.openai.promptCacheRetention": {
          "type": "string",
          "default": "in_memory",
          "description": "OpenAI/GPT prompt cache retention hint."
        },
        "kraken.providers.anthropic.thinking": {
          "type": "string",
          "default": "adaptive",
          "enum": [
            "auto",
            "adaptive",
            "enabled",
            "disabled"
          ],
          "description": "Claude thinking mode."
        },
        "kraken.providers.anthropic.effort": {
          "type": "string",
          "default": "medium",
          "enum": [
            "none",
            "minimal",
            "low",
            "medium",
            "high",
            "xhigh",
            "max"
          ],
          "description": "Claude output effort."
        },
        "kraken.providers.anthropic.thinkingBudgetTokens": {
          "type": "number",
          "default": 16000,
          "minimum": 0,
          "description": "Claude manual extended thinking budget in tokens."
        },
        "kraken.providers.anthropic.maxTokens": {
          "type": "number",
          "default": 32000,
          "minimum": 1,
          "description": "Claude max output tokens."
        },
        "kraken.providers.anthropic.preserveThinking": {
          "type": "boolean",
          "default": true,
          "description": "Preserve Claude thinking blocks across tool loops when supported."
        },
        "kraken.providers.anthropic.cacheTtl": {
          "type": "string",
          "default": "5m",
          "enum": [
            "5m",
            "1h"
          ],
          "description": "Claude ephemeral block cache TTL."
        },
        "kraken.providers.qwen.enableThinking": {
          "type": "boolean",
          "default": true,
          "description": "Enable Qwen thinking when supported."
        },
        "kraken.providers.qwen.thinkingBudget": {
          "type": "number",
          "default": 8192,
          "minimum": 0,
          "description": "Qwen thinking budget in tokens."
        },
        "kraken.providers.qwen.preserveThinking": {
          "type": "boolean",
          "default": false,
          "description": "Preserve Qwen reasoning content across tool loops when supported."
        },
        "kraken.providers.qwen.cacheMode": {
          "type": "string",
          "default": "auto",
          "enum": [
            "auto",
            "disabled"
          ],
          "description": "Qwen context cache mode. Auto lets Kraken choose the provider-specific cache settings."
        },
        "kraken.context.maxChars": {
          "type": "number",
          "default": 60000,
          "minimum": 2000,
          "description": "Maximum approximate context characters sent to the model."
        },
        "kraken.agent.autoApply": {
          "type": "boolean",
          "default": false,
          "description": "Apply generated changes automatically. Off by default."
        },
        "kraken.agent.browserBin": {
          "type": "string",
          "default": "agent-browser",
          "description": "Executable path for the agent_browser tool."
        },
        "kraken.agent.browserMaxOutput": {
          "type": "number",
          "default": 50000,
          "minimum": 1000,
          "description": "Maximum output characters returned by agent_browser."
        },
        "kraken.agent.browserDefaultTimeout": {
          "type": "number",
          "default": 25000,
          "minimum": 1000,
          "description": "Default timeout in milliseconds for agent_browser actions."
        },
        "kraken.agent.maxSteps": {
          "type": "number",
          "default": 8,
          "minimum": 1,
          "description": "Maximum ReAct steps before the agent stops."
        },
        "kraken.agent.browserAllowedDomains": {
          "type": "string",
          "default": "",
          "description": "Optional comma-separated domain allowlist for agent_browser."
        },
        "kraken.skills.dir": {
          "type": "string",
          "default": "",
          "description": "Optional skill install/discovery directory. Used when TOML [skills].dir is unset; falls back to KRAKEN_SKILLS_DIR or ~/kraken-coder/skills."
        },
        "kraken.lsp.adapter": {
          "type": "string",
          "default": "auto",
          "enum": [
            "auto",
            "vscode",
            "process"
          ],
          "description": "LSP adapter selection. VS Code currently uses vscode when auto."
        },
        "kraken.lsp.maxResults": {
          "type": "number",
          "default": 50,
          "minimum": 1,
          "description": "Default maximum LSP results returned to the model."
        },
        "kraken.lsp.hoverMaxChars": {
          "type": "number",
          "default": 4000,
          "minimum": 0,
          "description": "Maximum hover characters returned by LSP tools."
        },
        "kraken.lsp.timeoutMs": {
          "type": "number",
          "default": 8000,
          "minimum": 1000,
          "description": "Timeout in milliseconds for one LSP request."
        },
        "kraken.memory.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable persistent Kraken memory."
        },
        "kraken.memory.autoRead": {
          "type": "boolean",
          "default": true,
          "description": "Automatically read memory and inject it into the agent prompt."
        },
        "kraken.memory.maxChars": {
          "type": "number",
          "default": 8000,
          "minimum": 0,
          "description": "Maximum memory characters injected into one agent request."
        },
        "kraken.memory.allowWrite": {
          "type": "boolean",
          "default": false,
          "description": "Allow future memory tools to write memory."
        },
        "kraken.episodes.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable per-task episode storage and recall."
        },
        "kraken.episodes.autoCapture": {
          "type": "boolean",
          "default": true,
          "description": "Automatically capture completed agent runs as episodes."
        },
        "kraken.episodes.autoRecall": {
          "type": "boolean",
          "default": true,
          "description": "Automatically recall recent relevant episode summaries."
        },
        "kraken.episodes.maxRecalled": {
          "type": "number",
          "default": 3,
          "minimum": 0,
          "description": "Maximum number of episode summaries recalled into one agent request."
        },
        "kraken.episodes.maxChars": {
          "type": "number",
          "default": 12000,
          "minimum": 0,
          "description": "Maximum episode recall characters injected into one agent request."
        },
        "kraken.episodes.storeTranscript": {
          "type": "boolean",
          "default": true,
          "description": "Store full episode conversation transcripts as JSONL."
        },
        "kraken.sessions.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable workspace chat session switcher storage."
        }
      }
    }
  },
  "devDependencies": {
    "@types/node": "^20.12.12",
    "@types/vscode": "^1.90.0",
    "@vscode/vsce": "^3.9.1",
    "rimraf": "^6.1.3",
    "typescript": "^5.4.5"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/yjy233/kraken-coder.git"
  },
  "bugs": {
    "url": "https://github.com/yjy233/kraken-coder/issues"
  },
  "homepage": "https://github.com/yjy233/kraken-coder#readme",
  "keywords": [
    "ai",
    "agent",
    "assistant",
    "coding",
    "chat"
  ],
  "icon": "resources/icon.png",
  "galleryBanner": {
    "color": "#0f172a",
    "theme": "dark"
  }
}
